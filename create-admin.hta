<html>
<head>
<title>WIOM Admin Setup</title>
<HTA:APPLICATION ID="AdminSetup" APPLICATIONNAME="WIOM Admin" BORDER="dialog" SCROLL="no" SINGLEINSTANCE="yes"/>
<style>
body { font-family: Arial; background: #1a1a2e; color: white; margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh; }
.box { background: #16213e; padding: 30px; border-radius: 10px; text-align: center; width: 350px; }
h2 { color: #e94560; }
button { background: #e94560; color: white; border: none; padding: 12px 30px; border-radius: 6px; font-size: 15px; cursor: pointer; width: 100%; margin-top: 15px; }
#result { margin-top: 15px; padding: 10px; border-radius: 6px; font-size: 13px; }
</style>
</head>
<body>
<div class="box">
  <h2>WIOM IT Helpdesk</h2>
  <p>Admin Account Setup</p>
  <button onclick="createAdmin()">Admin Banao</button>
  <div id="result"></div>
</div>
<script language="VBScript">
Sub createAdmin()
  Dim xhr
  Set xhr = CreateObject("MSXML2.XMLHTTP.6.0")
  xhr.Open "POST", "https://web-production-ef6c1.up.railway.app/api/auth/setup-admin", False
  xhr.setRequestHeader "Content-Type", "application/json"
  xhr.Send "{""password"":""Wiom@2024""}"
  document.getElementById("result").innerHTML = "Status: " & xhr.Status & "<br>" & xhr.responseText
End Sub
</script>
</body>
</html>
