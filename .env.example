# ════════════════════════════════════════════════════════════════════
# WIOM IT Helpdesk — Environment Variables
# Copy this file to .env and fill in the values
# ════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── MongoDB Atlas ────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/wiom_helpdesk

# ── JWT Secret (make it long and random) ─────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here_change_this

# ── Claude AI (Anthropic) ────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail App Password) ───────────────────────────────────
# Gmail → Settings → Security → App Passwords → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sajan.kumar@wiom.in
SMTP_PASS=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=sajan.kumar@wiom.in

# ── Slack Bot ────────────────────────────────────────────────────
# All from: https://api.slack.com/apps → Your App → Credentials
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sajan's Slack User ID (right-click your name → Copy member ID)
SAJAN_SLACK_ID=U0XXXXXXXXX

# ── Admin JWT (for Slack → API calls) ───────────────────────────
# Generate after running setup-admin: POST /api/auth/admin-login
ADMIN_JWT_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Security ──────────────────────────────────────────────────────
SETUP_DISABLED=false
ALLOWED_ORIGINS=https://your-frontend-url.netlify.app,https://your-domain.com
SLACK_INTERNAL_SECRET=random_internal_secret_for_slack_to_api_calls

# ── API Base URL (your Railway deployment URL) ───────────────────
API_BASE_URL=https://wiom-helpdesk-production.up.railway.app
